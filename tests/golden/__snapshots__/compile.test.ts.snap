      "allow": [
        "**/test/**",
        "**/tests/**",
        "**/__tests__/**",
        "**/*.{test,spec}.{ts,tsx,js,jsx,py,go,rs,java,rb,php}",
        "**/*_test.go",
        "**/test_*.py"
      ],
      "deny": [
        "**/src/**",
        "**/lib/**"
      ]
    }
  }
}
