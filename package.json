{
  "name": "ai-sdlc",
  "version": "0.1.0",
  "description": "Cross-host AI SDLC framework: host-neutral base + /customize compiler for Cursor, Claude Code, and GitHub Copilot.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aisdlc": "./dist/cli/index.js"
  },
  "scripts": {
